# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
.eggs/

# uv — lock file is committed for reproducible builds

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/

# Type checkers
.mypy_cache/
.pyright/
pyrightconfig.json

# PyInstaller — ignore build artifacts but commit the spec file
build/*
!build/*.spec
*.spec.bak

# Logs
*.log
~/.xcde_editor/

# Real save files — kept locally for manual testing, never committed
saves/

